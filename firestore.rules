
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === Helper Functions ===

    function getUserData() {
      // Use exists() to prevent errors if the user document doesn't exist yet.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isApproved() {
      // Ensure getUserData() is not null before accessing properties.
      return isSignedIn()
        && getUserData() != null
        && getUserData().isApproved == true;
    }
    
    function isEditor() {
      return getUserData() != null && getUserData().role == 'editor';
    }

    function isSupervisor() {
      return isApproved() && getUserData() != null && getUserData().role == 'supervisor';
    }
    
    function isViewer() {
      return isApproved() && getUserData() != null && getUserData().role == 'viewer';
    }

    // A super admin is an editor without a specific office location.
    function isSuperAdmin() {
      return isEditor() && !('officeLocation' in getUserData());
    }

    // An office user is any approved user with an office location.
    function isOfficeUser() {
      return isApproved() && ('officeLocation' in getUserData());
    }

    // === Collection Rules ===

    // User Profiles
    match /users/{userId} {
      allow get: if isSuperAdmin() || request.auth.uid == userId || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow create: if request.auth.uid == userId; // Allow users to create their own profile
      allow update: if isSuperAdmin() || request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    // Main File Entries (Deposit Works)
    match /fileEntries/{docId} {
      allow get, list: if isSuperAdmin() || 
                          (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation) ||
                          (isSupervisor() && request.auth.uid in resource.data.assignedSupervisorUids);
      allow write: if isEditor();
    }

    // ARS Entries
    match /arsEntries/{docId} {
      allow get, list: if isSuperAdmin() ||
                          (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation) ||
                          (isSupervisor() && resource.data.supervisorUid == request.auth.uid);
      allow write: if isEditor();
    }
    
    // Pending Updates from Supervisors
    match /pendingUpdates/{docId} {
      allow create: if isSupervisor() || isEditor();
      allow read, list: if isEditor() || (isSupervisor() && resource.data.submittedByUid == request.auth.uid);
      allow update, delete: if isEditor();
    }

    // Staff Members (Establishment)
    match /staffMembers/{docId} {
      allow get, list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor();
    }
    
    // Agency Registrations
    match /agencyApplications/{docId} {
      allow get, list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor();
    }
    
    // eTenders
    match /eTenders/{docId} {
      allow get, list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor();
    }

    // Vehicle Management
    match /departmentVehicles/{docId} {
      allow get, list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor();
    }
    match /hiredVehicles/{docId} {
      allow get, list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor();
    }
    match /rigCompressors/{docId} {
      allow get, list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor();
    }

    // Office Addresses
    match /officeAddresses/{docId} {
      allow get, list: if isSuperAdmin() || (isOfficeUser() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isSuperAdmin() || (isEditor() && resource.data.officeLocation == getUserData().officeLocation);
    }
    
    // === Global Collections (Readable by any approved user) ===
    
    match /gwdRates/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }
    
    match /bidders/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }
    
    match /localSelfGovernments/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin() || isEditor();
    }

    match /rateDescriptions/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }
  }
}
