/*
================================================================================
  IMPORTANT NOTE ON SUPER ADMIN PERMISSIONS
================================================================================
  The 'isSuperAdmin()' function below relies on a Firebase Custom Claim.
  If the Super Admin user is seeing "Permission Denied" errors on LIST
  operations, it is because their authentication token is missing the
  required { superAdmin: true } claim.

  **THIS CANNOT BE FIXED WITH SECURITY RULES ALONE.**

  To fix this, you MUST set a custom claim on the super admin user's account
  using the Firebase Admin SDK (e.g., in a Node.js script or Cloud Function).

  Example Admin SDK code:
  -----------------------
  const admin = require("firebase-admin");

  // Initialize with your service account
  // admin.initializeApp({ ... });

  const SUPER_ADMIN_UID = "YOUR_SUPER_ADMIN_USER_UID";

  admin.auth().setCustomUserClaims(SUPER_ADMIN_UID, {
    superAdmin: true
  }).then(() => {
    console.log("Super admin claim set successfully!");
  });

  -----------------------

  After setting the claim, the Super Admin user MUST sign out and sign back in
  to refresh their authentication token.
================================================================================
*/
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS ================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isApproved() {
      return getUserData() != null && getUserData().isApproved == true;
    }

    function isEditor() {
      return isApproved() && getUserData().role == 'editor';
    }

    function isSupervisor() {
      return isApproved() && getUserData().role == 'supervisor';
    }

    function isViewer() {
      return isApproved() && getUserData().role == 'viewer';
    }

    function isSuperAdmin() {
      return request.auth.token.superAdmin == true;
    }

    function sameOffice() {
      return resource.data.officeLocation == getUserData().officeLocation;
    }

    function sameOfficeWrite() {
      return request.resource.data.officeLocation == getUserData().officeLocation;
    }

    /* ================= USERS ================= */

    match /users/{userId} {
      allow get, list: if
        isSuperAdmin() ||
        (isApproved() && sameOffice()) ||
        request.auth.uid == userId;

      allow create: if request.auth.uid == userId;

      allow update: if
        isSuperAdmin() ||
        request.auth.uid == userId;

      allow delete: if isSuperAdmin();
    }

    /* ================= FILE ENTRIES ================= */

    match /fileEntries/{docId} {
      allow get, list: if
        isSuperAdmin() ||
        (isApproved() && sameOffice()) ||
        (isSupervisor() && request.auth.uid in resource.data.assignedSupervisorUids);

      allow write: if
        isEditor() && sameOfficeWrite();
    }

    /* ================= ARS ENTRIES ================= */

    match /arsEntries/{docId} {
      allow get, list: if
        isSuperAdmin() ||
        (isApproved() && sameOffice()) ||
        (isSupervisor() && resource.data.supervisorUid == request.auth.uid);

      allow write: if
        isEditor() && sameOfficeWrite();
    }
    
    // Pending Updates from Supervisors
    match /pendingUpdates/{docId} {
      allow create: if isSupervisor() || isEditor();
      allow read, list: if isEditor() || (isSupervisor() && resource.data.submittedByUid == request.auth.uid);
      allow update, delete: if isEditor();
    }

    /* ================= OFFICE-SCOPED DATA ================= */

    function officeRead() {
      return isSuperAdmin() || (isApproved() && sameOffice());
    }

    function officeWrite() {
      return isEditor() && sameOfficeWrite();
    }

    match /staffMembers/{docId} {
      allow get, list: if officeRead();
      allow write: if officeWrite();
    }

    match /agencyApplications/{docId} {
      allow get, list: if officeRead();
      allow write: if officeWrite();
    }

    match /eTenders/{docId} {
      allow get, list: if officeRead();
      allow write: if officeWrite();
    }

    match /departmentVehicles/{docId} {
      allow get, list: if officeRead();
      allow write: if officeWrite();
    }

    match /hiredVehicles/{docId} {
      allow get, list: if officeRead();
      allow write: if officeWrite();
    }

    match /rigCompressors/{docId} {
      allow get, list: if officeRead();
      allow write: if officeWrite();
    }

    match /officeAddresses/{docId} {
      allow get, list: if officeRead();
      allow write: if isSuperAdmin() || officeWrite();
    }

    /* ================= GLOBAL DATA ================= */

    match /gwdRates/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }

    match /bidders/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }

    match /localSelfGovernments/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin() || isEditor();
    }

    match /rateDescriptions/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }
  }
}
