rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for roles and authentication status
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isApproved() {
      // isApproved is a field in the user's document in the /users collection.
      return isSignedIn() && getUserData().isApproved == true;
    }

    function isRole(role) {
      return isApproved() && getUserData().role == role;
    }

    function isEditor() {
      return isRole('editor');
    }

    function isSupervisor() {
      return isRole('supervisor');
    }
    
    function isViewer() {
      return isRole('viewer');
    }

    function isScopedReader() {
      return isEditor() || isViewer();
    }
    
    // === User Profiles ===
    match /users/{userId} {
      // Any signed in user can read their own profile.
      // Editors and viewers can read all profiles in their office.
      allow get: if request.auth.uid == userId || (isScopedReader() && resource.data.officeLocation == getUserData().officeLocation);
      allow list: if isScopedReader() && request.query.where.officeLocation == getUserData().officeLocation;

      // An editor can create any user profile in their office.
      // Any signed in user can create their own user profile document.
      allow create: if request.auth.uid == userId || (isEditor() && request.resource.data.officeLocation == getUserData().officeLocation);

      // An editor can update any profile in their office.
      // A user can only update their own lastActiveAt timestamp.
      allow update: if (isEditor() && resource.data.officeLocation == getUserData().officeLocation) || 
                     (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastActiveAt']));

      // Only an editor can delete a user profile in their office.
      allow delete: if isEditor() && resource.data.officeLocation == getUserData().officeLocation;
    }

    // === Main File Entries (Deposit Works) ===
    match /fileEntries/{docId} {
      allow get: if (isScopedReader() && resource.data.officeLocation == getUserData().officeLocation) || 
                  (isSupervisor() && request.auth.uid in resource.data.assignedSupervisorUids);
      allow list: if (isScopedReader() && request.query.where.officeLocation == getUserData().officeLocation) ||
                   (isSupervisor() && request.query.where.assignedSupervisorUids.array_contains == request.auth.uid);
      allow create: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
      allow update: if (isEditor() && resource.data.officeLocation == getUserData().officeLocation) || isSupervisor(); // Supervisors can update via pending updates
      allow delete: if isEditor() && resource.data.officeLocation == getUserData().officeLocation;
    }

    // === ARS Entries ===
    match /arsEntries/{docId} {
      allow get: if (isScopedReader() && resource.data.officeLocation == getUserData().officeLocation) || 
                  (isSupervisor() && resource.data.supervisorUid == request.auth.uid);
      allow list: if (isScopedReader() && request.query.where.officeLocation == getUserData().officeLocation) || 
                   (isSupervisor() && request.query.where.supervisorUid == request.auth.uid);
      allow create: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
      allow update: if (isEditor() && resource.data.officeLocation == getUserData().officeLocation) || isSupervisor();
      allow delete: if isEditor() && resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === Pending Updates from Supervisors ===
    match /pendingUpdates/{docId} {
      allow create: if isSupervisor() || isEditor();
      allow read, delete: if (isSupervisor() && request.auth.uid == resource.data.submittedByUid) || isEditor();
      allow update: if isEditor(); // Editors approve/reject by updating status
    }

    // === Staff Members (Establishment) ===
    match /staffMembers/{docId} {
      allow get: if isApproved();
      allow list: if isApproved() && request.query.where.officeLocation == getUserData().officeLocation;
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === Agency Registrations ===
    match /agencyApplications/{docId} {
      allow get: if isApproved();
      allow list: if isApproved() && request.query.where.officeLocation == getUserData().officeLocation;
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === GWD Rates (Global) ===
    match /gwdRates/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }
    
    // === eTenders ===
    match /eTenders/{docId} {
      allow get: if isApproved();
      allow list: if (isApproved() && request.query.where.officeLocation == getUserData().officeLocation) || 
                   (isEditor() && !('officeLocation' in request.query.where)); // Super admin case
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === Bidders (Global) ===
    match /bidders/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }

    // === Vehicle Management ===
    match /departmentVehicles/{docId} {
      allow get: if isScopedReader() || isSupervisor();
      allow list: if isScopedReader() && request.query.where.officeLocation == getUserData().officeLocation;
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }

    match /hiredVehicles/{docId} {
      allow get: if isScopedReader() || isSupervisor();
      allow list: if isScopedReader() && request.query.where.officeLocation == getUserData().officeLocation;
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }

    match /rigCompressors/{docId} {
      allow get: if isScopedReader() || isSupervisor();
      allow list: if isScopedReader() && request.query.where.officeLocation == getUserData().officeLocation;
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }

    // === App Settings (Global Dropdowns, etc.) ===
    match /officeAddresses/{docId} {
      // Specific rule to allow any approved user to read their own office details
      allow get: if isApproved() && resource.data.officeLocation == getUserData().officeLocation;
      allow list: if (isApproved() && request.query.where.officeLocation == getUserData().officeLocation) || 
                   (isEditor() && !('officeLocation' in request.query.where));
      allow write: if isEditor(); // Maybe super admin only
    }
    
    match /localSelfGovernments/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }

    match /constituencies/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }
    
    match /rateDescriptions/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }
  }
}
