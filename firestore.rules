
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS ================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isApproved() {
      let data = getUserData();
      return data != null && data.isApproved == true;
    }

    function getRole() {
      let data = getUserData();
      return data != null ? data.role : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (request.auth.token.email == "keralagwd@gmail.com" || getRole() == "superAdmin");
    }

    function isSubOfficeAdmin() {
      return isApproved() && getRole() == 'admin';
    }

    function isScientist() {
      return isApproved() && getRole() == 'scientist';
    }

    function isEngineer() {
      return isApproved() && getRole() == 'engineer';
    }

    function isSupervisor() {
      return isApproved() && getRole() == 'supervisor';
    }
    
    function isInvestigator() {
      return isApproved() && getRole() == 'investigator';
    }

    function isViewer() {
      return isApproved() && getRole() == 'viewer';
    }
    
    function sameOffice(officeId) {
      let data = getUserData();
      return data != null &&
             data.isApproved == true &&
             'officeLocation' in data &&
             data.officeLocation.lower() == officeId.lower();
    }

    /* ================= GLOBAL COLLECTIONS ================= */

    match /users/{userId} {
      function isManagingOwnOfficeUser() {
        return isSubOfficeAdmin() && request.resource.data.officeLocation.lower() == getUserData().officeLocation.lower();
      }
      
      allow get: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isSuperAdmin() || isSubOfficeAdmin();
      allow create: if isSuperAdmin() || isManagingOwnOfficeUser();
      allow update: if isSuperAdmin() || isManagingOwnOfficeUser() || (isApproved() && request.auth.uid == userId);
      allow delete: if isSuperAdmin() || (isSubOfficeAdmin() && getUserData().officeLocation.lower() == get(/databases/$(database)/documents/users/$(userId)).data.officeLocation.lower());
    }
    
    match /gwdRates/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }

    match /bidders/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin() || isSubOfficeAdmin() || isEngineer();
    }

    match /rateDescriptions/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }
    
    match /localSelfGovernments/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }

    match /officeAddresses/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }

    /* ================= OFFICE SUBCOLLECTIONS ================= */

    match /offices/{officeId} {
      allow read, write: if isSuperAdmin();
      
      function officeRead() {
        return isSuperAdmin() || sameOffice(officeId);
      }
      
      function canManageAll() {
        return isSuperAdmin() || (isSubOfficeAdmin() && sameOffice(officeId));
      }

      function canEditEngineering() {
        return canManageAll() || (isEngineer() && sameOffice(officeId));
      }

      function canEditScience() {
        return canManageAll() || ((isScientist() || isInvestigator()) && sameOffice(officeId));
      }

      match /users/{userId} {
        allow get: if officeRead() || isSupervisor() || isInvestigator();
        allow list: if isSignedIn();
        allow write: if canManageAll();
      }

      match /fileEntries/{docId} {
        allow get: if officeRead()
            || (isSupervisor() && request.auth.uid in resource.data.assignedSupervisorUids)
            || (isInvestigator() && request.auth.uid in resource.data.assignedInvestigatorUids);
        allow list: if isSignedIn();
        allow delete: if canManageAll();
        allow create, update: if canEditEngineering() || canEditScience();
      }

      match /arsEntries/{docId} {
        allow get: if officeRead() || ((isSupervisor() || isInvestigator()) && resource.data.supervisorUid == request.auth.uid);
        allow list: if isSignedIn();
        allow delete: if canManageAll();
        allow write: if canEditEngineering();
      }
      
      match /pendingUpdates/{docId} {
        allow create: if (isSupervisor() || isInvestigator()) && sameOffice(officeId);
        allow get: if canManageAll() || ((isSupervisor() || isInvestigator()) && resource.data.submittedByUid == request.auth.uid);
        allow list: if isSignedIn();
        allow update, delete: if canManageAll();
      }
      
      match /staffMembers/{docId} {
        allow read: if officeRead() || isSupervisor() || isInvestigator();
        allow write: if canManageAll();
      }

      match /agencyApplications/{docId} {
        allow read: if officeRead() || isSupervisor() || isInvestigator();
        allow delete: if canManageAll();
        allow write: if canEditEngineering();
      }

      match /eTenders/{docId} {
        allow read: if officeRead() || isSupervisor() || isInvestigator();
        allow delete: if canManageAll();
        allow write: if canEditEngineering();
      }

      match /departmentVehicles/{docId} {
        allow read: if officeRead() || isSupervisor() || isInvestigator();
        allow delete: if canManageAll();
        allow write: if canEditEngineering();
      }

      match /hiredVehicles/{docId} {
        allow read: if officeRead() || isSupervisor() || isInvestigator();
        allow delete: if canManageAll();
        allow write: if canEditEngineering();
      }

      match /rigCompressors/{docId} {
        allow read: if officeRead() || isSupervisor() || isInvestigator();
        allow delete: if canManageAll();
        allow write: if canEditEngineering();
      }
      
      match /bidders/{docId} {
        allow read: if officeRead() || isSupervisor() || isInvestigator();
        allow write: if canEditEngineering();
      }
      
      match /localSelfGovernments/{docId} {
          allow read: if officeRead() || isSupervisor() || isInvestigator();
          allow write: if canManageAll();
      }
      
       match /officeAddresses/{docId} {
          allow read: if officeRead() || isSupervisor() || isInvestigator();
          allow write: if canManageAll();
      }

      match /sanctionedStrength/{docId} {
          allow read: if officeRead() || isSupervisor() || isInvestigator();
          allow write: if canManageAll();
      }
    }
    
    /* ================= COLLECTION GROUP RULES FOR SUPER ADMIN LISTS ================= */

    match /{path=**}/fileEntries/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/arsEntries/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/staffMembers/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/agencyApplications/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/eTenders/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/departmentVehicles/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/hiredVehicles/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/rigCompressors/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/bidders/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/localSelfGovernments/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/officeAddresses/{docId} {
      allow read: if isApproved();
    }
    match /{path=**}/users/{userId} {
      allow read: if isSuperAdmin();
    }
    match /{path=**}/sanctionedStrength/{docId} {
      allow read: if isApproved();
    }
  }
}
