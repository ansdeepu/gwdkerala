
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      // Use exists() to prevent errors if the user document doesn't exist yet.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isApproved() {
      // Ensure getUserData() is not null before accessing properties.
      return isSignedIn()
        && getUserData() != null
        && getUserData().isApproved == true;
    }
    
    function isEditor() {
      // Super Admin check is implicit in the editor role for simplicity
      return isApproved() && getUserData() != null && getUserData().role == 'editor';
    }

    function isSupervisor() {
      return isApproved() && getUserData() != null && getUserData().role == 'supervisor';
    }
    
    function isViewer() {
      return isApproved() && getUserData() != null && getUserData().role == 'viewer';
    }

    function isScopedReader() {
      // A user who can read data scoped to their office.
      return isEditor() || isViewer() || isSupervisor();
    }
    
    // === User Profiles ===
    match /users/{userId} {
      allow get: if isEditor() || request.auth.uid == userId;
      allow list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow create: if request.auth.uid == userId;
      allow update: if isEditor() || (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastActiveAt']));
      allow delete: if isEditor();
    }

    // === Main File Entries (Deposit Works) ===
    match /fileEntries/{docId} {
      allow get: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow create: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
      allow update: if (isEditor() && resource.data.officeLocation == getUserData().officeLocation) || isSupervisor();
      allow delete: if isEditor() && resource.data.officeLocation == getUserData().officeLocation;
    }

    // === ARS Entries ===
    match /arsEntries/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow create, update: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
      allow delete: if isEditor() && resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === Pending Updates from Supervisors ===
    match /pendingUpdates/{docId} {
      allow create: if isSupervisor() || isEditor();
      allow read, delete: if isEditor() || (isSupervisor() && request.auth.uid == resource.data.submittedByUid);
      allow update: if isEditor();
    }

    // === Staff Members (Establishment) ===
    match /staffMembers/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === Agency Registrations ===
    match /agencyApplications/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === GWD Rates (Global) ===
    match /gwdRates/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }
    
    // === eTenders ===
    match /eTenders/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }
    
    // === Bidders (Global) ===
    match /bidders/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }

    // === Vehicle Management ===
    match /departmentVehicles/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }

    match /hiredVehicles/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }

    match /rigCompressors/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor() && request.resource.data.officeLocation == getUserData().officeLocation;
    }

    // === App Settings (Global Dropdowns, etc.) ===
    match /officeAddresses/{docId} {
      allow get, list: if isEditor() || (isApproved() && resource.data.officeLocation == getUserData().officeLocation);
      allow write: if isEditor();
    }
    
    match /localSelfGovernments/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }

    match /constituencies/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }
    
    match /rateDescriptions/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }
  }
}
