rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS ================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isApproved() {
      return getUserData() != null && getUserData().isApproved == true;
    }

    function isEditor() {
      return isApproved() && getUserData().role == 'editor';
    }

    function isSupervisor() {
      return isApproved() && getUserData().role == 'supervisor';
    }

    function isViewer() {
      return isApproved() && getUserData().role == 'viewer';
    }

    function isSuperAdmin() {
      return request.auth.token.email == "keralagwd@gmail.com";
    }

    function isOfficeUser() {
      return isApproved() && 'officeLocation' in getUserData();
    }

    function sameOffice(officeId) {
      return isOfficeUser() && officeId == getUserData().officeLocation.lower();
    }

    /* ================= GLOBAL COLLECTIONS ================= */

    match /users/{userId} {
      allow get: if
        isSuperAdmin() ||
        (isApproved() && request.auth.uid == userId);
      
      allow list: if isSuperAdmin() || isEditor();

      allow create: if isSuperAdmin() || request.auth.uid == userId;

      allow update: if isSuperAdmin() || request.auth.uid == userId;

      allow delete: if isSuperAdmin();
    }
    
    match /officeAddresses/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin() || isEditor();
    }

    match /gwdRates/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }

    match /bidders/{docId} {
      allow read: if isApproved();
      allow write: if isEditor();
    }

    match /localSelfGovernments/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin() || isEditor();
    }

    match /rateDescriptions/{docId} {
      allow read: if isApproved();
      allow write: if isSuperAdmin();
    }
    
    /* ================= OFFICE SUBCOLLECTIONS ================= */

    match /offices/{officeId} {
      // Allow super admin to create/manage office documents
      allow read, write: if isSuperAdmin();
      
      function officeRead() {
        return isSuperAdmin() || sameOffice(officeId);
      }
      
      function officeWrite() {
        return isSuperAdmin() || (isEditor() && sameOffice(officeId));
      }
      
      match /fileEntries/{docId} {
        allow get: if officeRead() || (isSupervisor() && request.auth.uid in resource.data.assignedSupervisorUids);
        allow list: if officeRead();
        allow write: if officeWrite();
      }

      match /arsEntries/{docId} {
        allow get: if officeRead() || (isSupervisor() && resource.data.supervisorUid == request.auth.uid);
        allow list: if officeRead();
        allow write: if officeWrite();
      }
      
      match /pendingUpdates/{docId} {
        allow create: if isSupervisor() || isEditor();
        allow read, list: if isEditor() || (isSupervisor() && resource.data.submittedByUid == request.auth.uid);
        allow update, delete: if isEditor();
      }
      
      match /staffMembers/{docId} {
        allow read: if officeRead();
        allow write: if officeWrite();
      }

      match /agencyApplications/{docId} {
        allow read: if officeRead();
        allow write: if officeWrite();
      }

      match /eTenders/{docId} {
        allow read: if officeRead();
        allow write: if officeWrite();
      }

      match /departmentVehicles/{docId} {
        allow read: if officeRead();
        allow write: if officeWrite();
      }

      match /hiredVehicles/{docId} {
        allow read: if officeRead();
        allow write: if officeWrite();
      }

      match /rigCompressors/{docId} {
        allow read: if officeRead();
        allow write: if officeWrite();
      }
    }
  }
}
